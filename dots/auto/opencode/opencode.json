{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "mcp": {
    "jina": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.jina.ai/v1",
      "headers": {
        "Authorization": "Bearer {env:JINA_API_KEY}"
      }
    },
    "context7": {
      "enabled": true,
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "environment": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "personal-notes": {
      "type": "local",
      "command": [
        "bash",
        "-lc",
        "cd ~/Documents/Notes && akuna mcp"
      ]
    },
    "pricefx-workspace": {
      "enabled": false,
      "type": "local",
      "command": [
        "bash",
        "-lc",
        "cd ~/Employer/workspace-product && akuna mcp"
      ]
    },
  }
}
